# Copy this file to `.env` and set your own checkout path. `.env` is gitignored,
# so Kit, Cam, and anyone else keep their own machine-specific value without
# clobbering each other or committing a hardcoded path.
#
# AOG_ROOT — absolute path to your local aog-necrology checkout. It is used only
# by pipeline/extract.workflow.js, which embeds it in the extraction subagents'
# prompts so they can read data/chunks/* and write data/extracted/parts/*.
# (The Python pipeline scripts derive their paths automatically and don't need it.)
#
# Windows (single backslashes are fine here):
#   AOG_ROOT=C:\Users\you\path\to\aog-necrology
# macOS / Linux:
#   AOG_ROOT=/home/you/aog-necrology
AOG_ROOT=
